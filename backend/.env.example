# LogistiQ AI backend environment example
# Copy this file to .env and replace placeholders with local or deployed values.
# Do not commit real .env files or secret values.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Use an async SQLAlchemy URL. For local Docker, match the user/password/db
# values configured in your compose file.
DATABASE_URL=postgresql+asyncpg://logistiq:<local_db_password>@localhost:5432/logistiq

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Security / JWT
# ---------------------------------------------------------------------------
# Generate a strong value, for example:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate_a_strong_random_secret_key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated frontend origins.
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Razorpay billing
# ---------------------------------------------------------------------------
# Leave blank to keep billing in safe dev/no-op mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STARTER_PLAN_ID=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_ENTERPRISE_PLAN_ID=

# ---------------------------------------------------------------------------
# External data sources
# ---------------------------------------------------------------------------
# Leave blank to disable live external data integrations.
NASA_FIRMS_KEY=
ORS_API_KEY=
FIREBASE_CREDENTIALS_JSON=

# ---------------------------------------------------------------------------
# Gemini / AI
# ---------------------------------------------------------------------------
# Leave GEMINI_API_KEY blank to use non-Gemini fallbacks where implemented.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
# Backend Google OAuth client ID. Use the same web client configured for the frontend.
GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# Agent configuration
# ---------------------------------------------------------------------------
PHASE_2_ENABLED=false
RISK_THRESHOLD_DELAY=0.70
RISK_THRESHOLD_CRITICAL=0.85
SENTINEL_POLL_INTERVAL_MINUTES=5
GDELT_POLL_INTERVAL_MINUTES=10
SIMULATION_DEMO_SPEED_MULTIPLIER=100.0
SIMULATION_DEMO_TICK_SECONDS=1.0

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
ENVIRONMENT=development
TESTING=false
