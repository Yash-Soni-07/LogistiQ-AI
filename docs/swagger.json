{
  "openapi": "3.1.0",
  "info": {
    "title": "LogistiQ AI API",
    "description": "AI-powered logistics disruption management platform. Multi-tenant, RLS-isolated, MCP-driven tool ecosystem.\n\n> **Note:** This file is a static snapshot. The live, always-up-to-date spec is served at `/openapi.json` when the backend is running, and viewable at `/docs` (Swagger UI) or `/redoc` (ReDoc).\n>\n> This file is auto-regenerated by the CI pipeline on every deploy to `main` via:\n> ```\n> curl https://logistiq-api.run.app/openapi.json > docs/swagger.json\n> ```",
    "version": "0.1.0",
    "contact": {
      "name": "LogistiQ AI Engineering",
      "url": "https://github.com/your-org/logistiq-ai"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development server"
    },
    {
      "url": "https://logistiq-api.run.app",
      "description": "GCP Cloud Run production"
    }
  ],
  "tags": [
    { "name": "auth",        "description": "Authentication — register, login, token refresh, logout" },
    { "name": "shipments",   "description": "Shipment CRUD and carrier management" },
    { "name": "disruptions", "description": "Disruption event management and spatial queries" },
    { "name": "analytics",   "description": "Aggregated KPIs, usage stats, risk heatmap" },
    { "name": "billing",     "description": "Stripe subscription management and webhook ingestion" },
    { "name": "websocket",   "description": "Real-time WebSocket channels" },
    { "name": "ops",         "description": "Health and readiness probes" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token obtained from /auth/login or /auth/register"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error":   { "type": "string", "example": "not_found" },
          "message": { "type": "string", "example": "Shipment abc-123 not found" },
          "field":   { "type": "string", "example": "weight_kg", "description": "Present on validation errors" },
          "detail":  { "type": "object", "description": "Optional extra context" }
        }
      },
      "Token": {
        "type": "object",
        "properties": {
          "access_token":  { "type": "string" },
          "refresh_token": { "type": "string" },
          "token_type":    { "type": "string", "example": "bearer" }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "total":  { "type": "integer" },
          "offset": { "type": "integer" },
          "limit":  { "type": "integer" },
          "items":  { "type": "array", "items": {} }
        }
      }
    }
  },
  "security": [{ "BearerAuth": [] }],
  "paths": {
    "/health": {
      "get": {
        "tags": ["ops"],
        "summary": "Liveness probe",
        "operationId": "health",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is up",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":  { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "logistiq-ai-backend" },
                    "env":     { "type": "string", "example": "production" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register a new tenant + admin user",
        "operationId": "register",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "company_name", "first_name", "last_name"],
                "properties": {
                  "email":        { "type": "string", "format": "email" },
                  "password":     { "type": "string", "minLength": 8 },
                  "company_name": { "type": "string" },
                  "first_name":   { "type": "string" },
                  "last_name":    { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tenant + user created, tokens returned",
                   "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Token" } } } },
          "400": { "description": "Email already registered" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Authenticate and obtain JWT tokens",
        "operationId": "login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email":    { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tokens",
                   "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Token" } } } },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["auth"],
        "summary": "Get current user profile",
        "operationId": "get_me",
        "responses": {
          "200": { "description": "User profile with tenant details" },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/shipments": {
      "get": {
        "tags": ["shipments"],
        "summary": "List shipments (paginated, filterable)",
        "operationId": "list_shipments",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "mode",   "in": "query", "schema": { "type": "string" } },
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "Paginated shipment list",
                   "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } }
        }
      },
      "post": {
        "tags": ["shipments"],
        "summary": "Create a new shipment",
        "operationId": "create_shipment",
        "responses": {
          "201": { "description": "Shipment created" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/shipments/{shipment_id}": {
      "get": {
        "tags": ["shipments"],
        "summary": "Get shipment by ID",
        "operationId": "get_shipment",
        "parameters": [{ "name": "shipment_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Shipment detail" },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "patch": {
        "tags": ["shipments"],
        "summary": "Update shipment (partial)",
        "operationId": "update_shipment",
        "parameters": [{ "name": "shipment_id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated shipment" } }
      },
      "delete": {
        "tags": ["shipments"],
        "summary": "Cancel (soft-delete) a shipment",
        "operationId": "cancel_shipment",
        "parameters": [{ "name": "shipment_id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "204": { "description": "Cancelled" } }
      }
    },
    "/disruptions": {
      "get": {
        "tags": ["disruptions"],
        "summary": "List disruption events",
        "operationId": "list_disruptions",
        "parameters": [
          { "name": "type",     "in": "query", "schema": { "type": "string" } },
          { "name": "severity", "in": "query", "schema": { "type": "string" } },
          { "name": "status",   "in": "query", "schema": { "type": "string", "default": "active" } }
        ],
        "responses": { "200": { "description": "Paginated disruptions" } }
      },
      "post": {
        "tags": ["disruptions"],
        "summary": "Manually report a disruption (MANAGER+)",
        "operationId": "report_disruption",
        "responses": {
          "201": { "description": "Disruption created" },
          "403": { "description": "Insufficient role" }
        }
      }
    },
    "/disruptions/{disruption_id}/resolve": {
      "patch": {
        "tags": ["disruptions"],
        "summary": "Resolve a disruption (MANAGER+)",
        "operationId": "resolve_disruption",
        "parameters": [{ "name": "disruption_id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Disruption resolved" },
          "422": { "description": "Already resolved" }
        }
      }
    },
    "/analytics/summary": {
      "get": {
        "tags": ["analytics"],
        "summary": "Aggregated shipment KPIs for the tenant",
        "operationId": "analytics_summary",
        "responses": { "200": { "description": "KPI summary object" } }
      }
    },
    "/billing/subscribe": {
      "post": {
        "tags": ["billing"],
        "summary": "Create a Stripe subscription (ADMIN only)",
        "operationId": "subscribe",
        "responses": {
          "201": { "description": "Subscription created (or dev-mode stub)" }
        }
      }
    },
    "/billing/webhook": {
      "post": {
        "tags": ["billing"],
        "summary": "Stripe webhook ingestion endpoint",
        "operationId": "stripe_webhook",
        "security": [],
        "responses": {
          "200": { "description": "Event processed" },
          "400": { "description": "Invalid signature or Stripe not configured" }
        }
      }
    },
    "/ws/shipments/{shipment_id}": {
      "get": {
        "tags": ["websocket"],
        "summary": "WebSocket: live shipment telemetry (connect via WS, not HTTP GET)",
        "operationId": "ws_shipment",
        "parameters": [
          { "name": "shipment_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" }, "description": "JWT access token" }
        ],
        "responses": { "101": { "description": "WebSocket upgrade" } }
      }
    },
    "/ws/disruptions": {
      "get": {
        "tags": ["websocket"],
        "summary": "WebSocket: tenant-wide disruption alert broadcast",
        "operationId": "ws_disruptions",
        "parameters": [
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "101": { "description": "WebSocket upgrade" } }
      }
    },
    "/ws/dashboard": {
      "get": {
        "tags": ["websocket"],
        "summary": "WebSocket: aggregated KPI stream (ticks every 30s)",
        "operationId": "ws_dashboard",
        "parameters": [
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "101": { "description": "WebSocket upgrade" } }
      }
    }
  }
}
