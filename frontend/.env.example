# LogistiQ AI frontend environment example
# Copy this file to .env and fill only public browser-safe values.
# Every VITE_* variable is bundled into client-side JavaScript.

# Backend REST API base URL. Keep the /api/v1 suffix.
VITE_API_URL=http://localhost:8000/api/v1

# Backend WebSocket origin. Do not include /ws here; the app adds it.
VITE_WS_URL=ws://localhost:8000

# Google OAuth browser client ID. Leave blank to disable real Google sign-in locally.
VITE_GOOGLE_CLIENT_ID=

# Razorpay Checkout public key ID. This is a browser-safe public key, not the secret.
VITE_RAZORPAY_KEY_ID=

# Optional MapLibre style URL used by the tracking map.
VITE_STADIA_MAPS_STYLE=https://tiles.stadiamaps.com/styles/alidade_smooth_dark.json

# Dashboard simulation autostart. Set to false to prevent automatic demo startup.
VITE_ENABLE_SIMULATION_AUTOSTART=true

# Frontend environment label.
VITE_ENVIRONMENT=development
